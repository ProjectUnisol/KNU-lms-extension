{
  "name": "canvasbridge",
  "displayName": "CanvasBridge",
  "description": "CanvasBridge is an extension that allows you to use the features of the Canvas learning management system.",
  "version": "0.0.2",
  "vsce": {
    "baseImagesUrl": "https://raw.githubusercontent.com/ModakTeam/canvasbridge/main"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ModakTeam/canvasbridge.git"
  },
  "engines": {
    "vscode": "^1.89.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lmsContainer",
          "title": "CanvasBridge",
          "icon": "resources/canvasbridge_logo.svg"
        }
      ]
    },
    "views": {
      "lmsContainer": [
        {
          "id": "course",
          "name": "course"
        },
        {
          "id": "assignment",
          "name": "assignment"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "course.refreshEntry",
          "when": "view == course",
          "group": "navigation"
        }
      ]
    },
    "commands": [
      {
        "command": "course.refreshEntry",
        "title": "refresh",
        "icon": {
          "light": "resources/light/refresh.svg",
          "dark": "resources/dark/refresh.svg"
        }
      },
      {
        "command": "course.listAssignment",
        "title": "list assignment"
      },
      {
        "command": "assignment.displayAssignmentPage",
        "title": "display assignment page"
      }
    ], 
    "configuration": {
      "type": "object",
      "title": "CanvasBridge Configuration",
      "properties": {
        "canvasbridge.baseURL": {
          "type": "string",
          "default": "",
          "description": "LMS의 API를 사용하기 위한 기본 URL을 입력해주세요."
        },
        "canvasbridge.token": {
          "type": "string",
          "default": "",
          "description": "LMS의 API를 사용하기 위한 토큰을 입력해주세요."
        },
        "canvasbridge.assignmentPageTheme": {
          "type": "string",
          "default": "light",
          "description": "과제 페이지의 테마를 선택해주세요.",
          "enum": ["light", "dark"]
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.89.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser": "^7.7.1",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.3.9"
  }
}
